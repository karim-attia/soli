{
  "expo": {
    "name": "Soli",
    "slug": "soli",
    "version": "0.8.0",
    "description": "A polished Klondike Solitaire experience with responsive animations and a solvable shuffle catalog.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soli",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.karimattia.soli",
      "buildNumber": "13",
      "deploymentTarget": "16.4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0b8b3c"
      },
      "package": "ch.karimattia.soli",
      "versionCode": 13,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "backgroundColor": "#0b8b3c",
      "display": "standalone",
      "themeColor": "#0b8b3c"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "CardTextAndroid",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/CardTextAndroid.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/CardTextAndroid-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/CardTextAndroid-Bold.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/CardTextAndroid.ttf",
              "./assets/fonts/CardTextAndroid-SemiBold.ttf",
              "./assets/fonts/CardTextAndroid-Bold.ttf"
            ]
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#416F57",
          "image": "./assets/images/icon.png",
          "imageWidth": 368,
          "resizeMode": "contain"
        }
      ],
      "expo-status-bar",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9de7c7ee-2f1d-418d-ad51-eee7ede5d609"
      }
    }
  }
}
