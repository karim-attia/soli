{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "plugins": ["typescript", "oxc", "react", "import"],
  "rules": {
    "no-unassigned-import": "off",
    "react-in-jsx-scope": "off",
    "jsx-uses-react": "off",
    "style-prop-object": "off"
  },
  "ignorePatterns": ["dist/**", "build/**"]
}
