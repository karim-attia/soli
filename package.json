{
  "name": "soli",
  "version": "0.8.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "check:tamagui": "tamagui check",
    "generate:tamagui-css": "tamagui generate-css --output ./tamagui-web.css",
    "format": "oxfmt \"{app,components,modules,src,scripts,test}/**/*.{js,jsx,ts,tsx,json}\" package.json",
    "format:check": "oxfmt --check \"{app,components,modules,src,scripts,test}/**/*.{js,jsx,ts,tsx,json}\" package.json",
    "lint": "oxlint --tsconfig tsconfig.json app components modules src scripts test",
    "lint:fix": "oxlint --fix --tsconfig tsconfig.json app components modules src scripts test",
    "lint:strict": "oxlint -D correctness -D suspicious -A react-in-jsx-scope -A no-unassigned-import --deny-warnings --tsconfig tsconfig.json app components modules src scripts test",
    "typecheck": "tsc -p tsconfig.json",
    "start": "expo start -c",
    "release": "./run-android-release.sh",
    "ios": "node scripts/build-install-ios.js",
    "deeplink": "node scripts/deeplink.js",
    "celebration": "node scripts/deeplink.js celebration",
    "scrubtest": "node scripts/deeplink.js scrubtest",
    "nearwin": "node scripts/deeplink.js nearwin",
    "seedhistory": "node scripts/deeplink.js seedhistory",
    "build:ios": "npx eas build --platform ios --profile production --non-interactive",
    "web": "pkill -f 'expo.*start.*web' 2>/dev/null || true && BROWSER=none expo start --web --port 8081",
    "test": "jest --watchAll",
    "generate:solvable-deals": "node scripts/generate-solvable-deals-v2.js",
    "build:android": "./build-android.sh",
    "prebuild": "yarn prebuild:android",
    "prebuild:android": "npx expo prebuild --platform android --clean",
    "prebuild:ios": "npx expo prebuild --platform ios --clean"
  },
  "dependencies": {
    "@expo/material-symbols": "^0.1.1",
    "@expo/ui": "~57.0.4",
    "@shopify/react-native-skia": "2.6.2",
    "@tamagui/colors": "2.4.2",
    "@tamagui/config": "2.4.2",
    "@tamagui/font-inter": "2.4.2",
    "@tamagui/lucide-icons-2": "2.4.2",
    "@tamagui/native": "2.4.2",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-teleport": "1.1.9",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.1",
    "tamagui": "2.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native/jest-preset": "^0.86.0",
    "@tamagui/babel-plugin": "2.4.2",
    "@tamagui/cli": "2.4.2",
    "@tamagui/metro-plugin": "2.4.2",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.17",
    "agent-device": "0.19.0",
    "babel-preset-expo": "~57.0.2",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "jest-pnp-resolver": "^1.2.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.73.0",
    "typescript": "^7.0.2"
  },
  "dependenciesMeta": {
    "@shopify/react-native-skia": {
      "built": true
    }
  },
  "jest": {
    "moduleNameMapper": {
      "^expo-sqlite$": "<rootDir>/test/mocks/expo-sqlite",
      "^expo-sqlite/kv-store$": "<rootDir>/test/mocks/expo-sqlite-kv-store",
      "^expo/src/winter$": "<rootDir>/test/mocks/expo-winter",
      "^expo/src/winter/.*": "<rootDir>/test/mocks/expo-winter",
      "^expo/winter$": "<rootDir>/test/mocks/expo-winter",
      "^expo/winter/.*": "<rootDir>/test/mocks/expo-winter"
    },
    "preset": "jest-expo",
    "resolver": "jest-pnp-resolver",
    "setupFiles": [
      "<rootDir>/test/setup/mock-expo-winter.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|expo-modules-core|@expo|@react-native|react-native|react-native-reanimated)/)"
    ]
  },
  "packageManager": "yarn@4.17.1",
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets",
        "typescript"
      ]
    }
  }
}
