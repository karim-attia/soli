{
  "name": "soli",
  "version": "0.8.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "check:tamagui": "tamagui check",
    "generate:tamagui-css": "tamagui generate-css --output ./tamagui-web.css",
    "format": "oxfmt \"{app,components,modules,src,scripts,test}/**/*.{js,jsx,ts,tsx,json}\" package.json",
    "format:check": "oxfmt --check \"{app,components,modules,src,scripts,test}/**/*.{js,jsx,ts,tsx,json}\" package.json",
    "lint": "oxlint --tsconfig tsconfig.json app components modules src scripts test",
    "lint:fix": "oxlint --fix --tsconfig tsconfig.json app components modules src scripts test",
    "lint:strict": "oxlint -D correctness -D suspicious -A react-in-jsx-scope -A no-unassigned-import --deny-warnings --tsconfig tsconfig.json app components modules src scripts test",
    "typecheck": "tsgo -p tsconfig.json",
    "start": "expo start -c",
    "android": "expo run:android",
    "release": "./run-android-release.sh",
    "prod": "node scripts/run-demo-autosolve.js --mode=prod",
    "prod:no-timeout": "node scripts/run-demo-autosolve.js --mode=prod --no-prod-timeout",
    "ios": "expo run:ios",
    "build:ios": "npx eas build --platform ios --profile production --non-interactive",
    "web": "pkill -f 'expo.*start.*web' 2>/dev/null || true && BROWSER=none expo start --web --port 8081",
    "test": "jest --watchAll",
    "generate:solvable-deals": "node scripts/generate-solvable-deals-v2.js",
    "demo:auto-solve": "node scripts/run-demo-autosolve.js",
    "build:android": "./build-android.sh",
    "prebuild": "yarn prebuild:android",
    "prebuild:android": "npx expo prebuild --platform android --clean",
    "prebuild:ios": "npx expo prebuild --platform ios --clean"
  },
  "dependencies": {
    "@expo/ui": "~56.0.18",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tamagui/colors": "2.2.0",
    "@tamagui/config": "2.2.0",
    "@tamagui/font-inter": "2.2.0",
    "@tamagui/lucide-icons-2": "2.2.0",
    "@tamagui/native": "2.2.0",
    "@tamagui/toast": "2.2.0",
    "babel-preset-expo": "~56.0.0",
    "expo": "^56.0.0",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "jest-expo": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-teleport": "1.1.9",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "tamagui": "2.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@expo/metro-runtime": "~56.0.15",
    "@react-native/jest-preset": "0.85.3",
    "@tamagui/babel-plugin": "2.2.0",
    "@tamagui/cli": "2.2.0",
    "@tamagui/metro-plugin": "2.2.0",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "jest": "~29.7.0",
    "jest-pnp-resolver": "^1.2.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0"
  },
  "jest": {
    "moduleNameMapper": {
      "^expo-sqlite$": "<rootDir>/test/mocks/expo-sqlite",
      "^expo/src/winter$": "<rootDir>/test/mocks/expo-winter",
      "^expo/src/winter/.*": "<rootDir>/test/mocks/expo-winter",
      "^expo/winter$": "<rootDir>/test/mocks/expo-winter",
      "^expo/winter/.*": "<rootDir>/test/mocks/expo-winter"
    },
    "preset": "jest-expo",
    "resolver": "jest-pnp-resolver",
    "setupFiles": [
      "<rootDir>/test/setup/mock-expo-winter.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|expo-modules-core|@expo|@react-native|react-native|@react-native-async-storage|react-native-reanimated)/)"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
