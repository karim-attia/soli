{
  "name": "soli",
  "version": "0.5.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "upgrade:tamagui": "yarn up '*tamagui*'@latest '@tamagui/*'@latest",
    "upgrade:tamagui:canary": "yarn up '*tamagui*'@canary '@tamagui/*'@canary",
    "check:tamagui": "tamagui check",
    "format": "oxfmt \"{app,components,modules,src,scripts,test}/**/*.{js,jsx,ts,tsx,json}\" package.json",
    "format:check": "oxfmt --check \"{app,components,modules,src,scripts,test}/**/*.{js,jsx,ts,tsx,json}\" package.json",
    "lint": "oxlint --tsconfig tsconfig.json app components modules src scripts test",
    "lint:fix": "oxlint --fix --tsconfig tsconfig.json app components modules src scripts test",
    "lint:strict": "oxlint -D correctness -D suspicious -A react-in-jsx-scope -A jsx-uses-react -A no-unassigned-import --deny-warnings --tsconfig tsconfig.json app components modules src scripts test",
    "typecheck": "yarn typecheck:tsgo",
    "typecheck:tsc": "tsc -p tsconfig.json --noEmit",
    "typecheck:tsgo": "tsgo -p tsconfig.tsgo.json",
    "typecheck:fallback": "yarn typecheck:tsc",
    "start": "expo start -c",
    "android": "expo run:android",
    "release": "expo run:android --variant release",
    "prod": "node scripts/run-demo-autosolve.js --mode=prod",
    "prod:no-timeout": "node scripts/run-demo-autosolve.js --mode=prod --no-prod-timeout",
    "ios": "expo run:ios",
    "build:ios": "npx eas build --platform ios --profile production --non-interactive",
    "web": "pkill -f 'expo.*start.*web' 2>/dev/null || true && BROWSER=none expo start --web --port 8081",
    "test": "jest --watchAll",
    "harvest:trial": "node scripts/harvest-solvable.js --trial",
    "harvest:100": "node scripts/harvest-solvable.js --target=100",
    "demo:auto-solve": "node scripts/run-demo-autosolve.js",
    "build:android": "./build-android.sh",
    "prebuild": "npx expo prebuild --platform android --clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/native": "^7.1.28",
    "@tamagui/config": "^1.140.3",
    "@tamagui/lucide-icons": "^1.140.3",
    "@tamagui/toast": "^1.140.3",
    "babel-preset-expo": "^55.0.0",
    "burnt": "^0.13.0",
    "expo": "^55.0.0",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "jest-expo": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "tamagui": "^1.140.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@expo/metro-runtime": "~55.0.6",
    "@tamagui/babel-plugin": "^1.140.3",
    "@tamagui/cli": "^1.140.3",
    "@tamagui/metro-plugin": "^1.140.3",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "jest": "~29.7.0",
    "jest-pnp-resolver": "^1.2.3",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleNameMapper": {
      "^expo/src/winter$": "<rootDir>/test/mocks/expo-winter",
      "^expo/src/winter/.*": "<rootDir>/test/mocks/expo-winter",
      "^expo/winter$": "<rootDir>/test/mocks/expo-winter",
      "^expo/winter/.*": "<rootDir>/test/mocks/expo-winter"
    },
    "preset": "jest-expo",
    "resolver": "jest-pnp-resolver",
    "setupFiles": [
      "<rootDir>/test/setup/mock-expo-winter.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(expo|expo-modules-core|@expo|@react-native|react-native|@react-navigation|@react-native-async-storage|react-native-reanimated)/)"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
